// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Providers
    match /providers/{providerId} {
      allow read: if true;
      allow create: if isAuth() && isOwner(providerId);
      allow update: if isOwner(providerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow delete: if isAdmin();
    }

    // Conversations
    match /conversations/{convId} {
      allow read: if isAuth() && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();
    }

    // Messages
    match /messages/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAdmin();
    }

    // Categories
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics Events
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow create: if true; // Track anonymous visits
    }
  }
}
